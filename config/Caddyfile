{
    admin localhost:2019
    auto_https off
}

:8080 {
    header Content-Security-Policy "frame-ancestors 'self' localhost:8501 127.0.0.1:8501"

    handle /api/kernels/* {
        reverse_proxy localhost:8888
    }

    handle /artifacts/* {
        root * /var/lib/sandbox-artifacts
        file_server
    }

    handle /health {
        respond "ok" 200
    }
}
